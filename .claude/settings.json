{
  "mcpServers": {
    "browser": {
      "command": "npx",
      "args": [
        "@playwright/mcp",
        "--browser", "chromium",
        "--user-data-dir", "C:/Blopus/memory-store/chrome-profiles/mcp-browser",
        "--viewport", "1280,900",
        "--headless"
      ],
      "env": {}
    },
    "google-workspace": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-workspace"],
      "env": {
        "GOOGLE_CLIENT_ID": "${GOOGLE_CLIENT_ID}",
        "GOOGLE_CLIENT_SECRET": "${GOOGLE_CLIENT_SECRET}",
        "GOOGLE_REFRESH_TOKEN": "${GOOGLE_REFRESH_TOKEN}"
      }
    }
  },
  "permissions": {
    "allow": [
      "mcp__browser__browser_navigate",
      "mcp__browser__browser_snapshot",
      "mcp__browser__browser_click",
      "mcp__browser__browser_type",
      "mcp__browser__browser_fill",
      "mcp__browser__browser_screenshot",
      "mcp__browser__browser_wait_for",
      "mcp__browser__browser_key",
      "mcp__browser__browser_select_option",
      "mcp__browser__browser_scroll",
      "mcp__browser__browser_hover",
      "mcp__browser__browser_drag",
      "mcp__browser__browser_evaluate",
      "mcp__browser__browser_tab_new",
      "mcp__browser__browser_tab_close",
      "mcp__browser__browser_tab_list",
      "mcp__browser__browser_tab_select",
      "mcp__browser__browser_close",
      "mcp__browser__browser_resize",
      "mcp__browser__browser_network_requests",
      "mcp__browser__browser_console_messages",
      "mcp__browser__browser_file_upload",
      "mcp__browser__browser_handle_dialog",
      "mcp__browser__browser_pdf_save",
      "mcp__browser__browser_take_screenshot",
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ]
  }
}
